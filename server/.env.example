# Copy to .env and fill in. The .env file is gitignored.
PORT=3001

# In production, lock this to your site.
CLIENT_ORIGIN=https://meet.elloindia.in

# NOTE: TURN is no longer configured here. LiveKit ships its own (see
# deploy/livekit/livekit.yaml), so the old Metered credentials are gone.

# LiveKit SFU — carries all media. Without these three the app runs but no
# audio or video can flow, and the UI will say so. Generate the pair with:
#   docker run --rm livekit/livekit-server generate-keys
# The secret must match deploy/livekit/livekit.yaml and must NEVER be sent to a
# browser; clients only ever receive a short-lived token scoped to one room.
LIVEKIT_URL=wss://meet.elloindia.in/livekit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Horizontal scaling. Unset = single instance with in-memory rooms, which is
# correct and fast for one server. Set it and rooms move to Valkey/Redis and
# Socket.IO broadcasts route through it, so N instances behave as one.
# Both halves come from this one variable — see index.js.
#   REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=

# Room capacity. 20 is safe now that media goes through the SFU; it was capped
# at 4 while clients meshed, because a mesh cannot carry 20 people.
MAX_PEERS=20
