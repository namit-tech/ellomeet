# Copy to .env and fill in. The .env file is gitignored.
PORT=3001

# In production, lock this to your site.
CLIENT_ORIGIN=https://meet.elloindia.in

# Metered TURN credentials (https://dashboard.metered.ca). Optional in dev —
# without them the app falls back to Google STUN (works on most home networks).
METERED_DOMAIN=your-subdomain.metered.live
METERED_API_KEY=your_api_key_here
