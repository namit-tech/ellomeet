# Build-time config for `npm run build`. Vite inlines these into the bundle.
#
# The API lives on its own subdomain, so the old "same origin" default is wrong:
# meet.elloindia.in serves only the static app and has no /socket.io/ route.
# Without this the built client tries to open a socket against the static host
# and fails with "websocket error" forever.
VITE_SIGNALING_URL=https://meetapi.elloindia.in
